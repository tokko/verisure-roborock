# Verisure credentials
VERISURE_EMAIL=you@example.com
VERISURE_PASSWORD=your_password

# Installation ID — leave empty to auto-discover on first run
VERISURE_GIID=

# Override if you are outside Europe (e.g. https://e-api02.verisure.com/xbn/2)
VERISURE_BASE_URL=https://e-api01.verisure.com/xbn/2

# Base32 TOTP secret — only needed if 2FA is enabled on your account
VERISURE_OTP_SECRET=

# Roborock account credentials (for 'make fetch-tokens' — may differ from Verisure)
# If same as Verisure, leave blank and VERISURE_EMAIL/PASSWORD will be used as fallback.
ROBOROCK_EMAIL=you@example.com
ROBOROCK_PASSWORD=your_roborock_password

# Roborock vacuums — add ROBOROCK_1_*, ROBOROCK_2_*, etc. for additional vacuums
ROBOROCK_0_HOST=192.168.1.50
ROBOROCK_0_TOKEN=aabbccddeeff00112233445566778899   # 32-char hex from Mi Home
ROBOROCK_0_NAME=kitchen                              # optional log label

# ROBOROCK_1_HOST=192.168.1.51
# ROBOROCK_1_TOKEN=...
# ROBOROCK_1_NAME=upstairs

# Timing
POLL_INTERVAL=60s       # how often to poll Verisure alarm state
CLEAN_COOLDOWN=24h      # don't auto-start a vacuum if it cleaned within this window
ROBOROCK_TIMEOUT=10s    # per-UDP-command deadline

# Persistence
STORE_PATH=./state.json

# Observability
HTTP_ADDR=:8080
LOG_LEVEL=info          # debug | info | warn | error
