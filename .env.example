# Verisure credentials
VERISURE_EMAIL=you@example.com
VERISURE_PASSWORD=your_password

# Installation ID — leave empty to auto-discover on first run
VERISURE_GIID=

# Override if you are outside Europe (e.g. https://e-api02.verisure.com/xbn/2)
VERISURE_BASE_URL=https://e-api01.verisure.com/xbn/2

# Base32 TOTP secret — only needed if 2FA is enabled on your account
VERISURE_OTP_SECRET=

# Roborock account credentials (for 'make fetch-tokens' — may differ from Verisure)
# If same as Verisure, leave blank and VERISURE_EMAIL/PASSWORD will be used as fallback.
ROBOROCK_EMAIL=you@example.com
ROBOROCK_PASSWORD=your_roborock_password
ROBOROCK_CONTROL=roborock   # roborock | xiaomi | mixed | local
ROBOROCK_AUTH_PATH=./roborock-auth.json
ROBOROCK_HELPER=./scripts/roborock_cloud.py
ROBOROCK_PYTHON=python3
XIAOMI_COUNTRY=de
XIAOMI_AUTH_PATH=./xiaomi-auth.json

# Optional one-time Xiaomi auth import. If set, the app caches these to XIAOMI_AUTH_PATH.
# See README "Xiaomi Cloud sign-in" for how to obtain them from a browser session.
# XIAOMI_USER_ID=
# XIAOMI_SSECURITY=
# XIAOMI_SERVICE_TOKEN=

# Roborock vacuums — add ROBOROCK_1_*, ROBOROCK_2_*, etc. for additional vacuums
# BACKEND defaults to ROBOROCK_CONTROL. Use BACKEND=xiaomi for old Mi Home-only robots.
ROBOROCK_0_HOST=192.168.1.50
ROBOROCK_0_NAME=kitchen
# ROBOROCK_0_BACKEND=roborock
# ROBOROCK_0_DID=123456789                           # Xiaomi device ID, or Roborock DUID if selecting by ID
# ROBOROCK_0_TOKEN=aabbccddeeff00112233445566778899  # required only for local UDP

# ROBOROCK_1_HOST=192.168.1.51
# ROBOROCK_1_NAME=upstairs
# ROBOROCK_1_BACKEND=roborock

# Example Mi Home/Xiaomi-only robot:
# ROBOROCK_2_NAME=gizmo
# ROBOROCK_2_BACKEND=xiaomi
# ROBOROCK_2_DID=123456789

# Timing
POLL_INTERVAL=60s       # how often to poll Verisure alarm state
CLEAN_COOLDOWN_ENABLED=true  # set false to run on every armed-away transition
CLEAN_COOLDOWN=24h      # don't auto-start a vacuum if it cleaned within this window
ROBOROCK_TIMEOUT=10s    # per-UDP-command deadline (local mode)

# Persistence
STORE_PATH=./state.json

# Observability
HTTP_ADDR=:8080
LOG_LEVEL=info          # debug | info | warn | error
